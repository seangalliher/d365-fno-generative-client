{
  "name": "d365-generative-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/mcp-bridge.ts\"",
    "dev:client": "vite",
    "dev:bridge": "tsx watch server/mcp-bridge.ts",
    "build": "tsc -b && vite build",
